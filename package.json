{
  "name": "sc-next-electron",
  "displayName": "Electronjs with Nextjs",
  "version": "8.0.1",
  "description": "Electronjs with Nextjs",
  "private": false,
  "license": "MIT",
  "main": "dist/index.js",
  "author": {
    "name": "Saulo Costa",
    "email": "saulotarsobc@gmail.com",
    "url": "https://github.com/saulotarsobc"
  },
  "scripts": {
    "dev": "npm run build:backend && electron . --dev",
    "build:frontend": "next build frontend",
    "build:backend": "tsc -p backend",
    "prebuild": "rimraf build && rimraf dist && rimraf out && rimraf frontend/.next && rimraf frontend/out",
    "build": "npm run build:frontend && npm run build:backend",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@mantine/core": "^7.15.2",
    "@mantine/hooks": "^7.15.2",
    "@mantine/modals": "^7.15.2",
    "@mantine/notifications": "^7.15.2",
    "@tabler/icons-react": "^3.26.0",
    "app-root-path": "^3.1.0",
    "electron-log": "^5.1.5",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.3",
    "sharp": "^0.33.5",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "next": "^14.2.22",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.10",
    "typescript": "^5.7.2"
  }
}
